{
    "name": "bynhan/sharp",
    "description": "A fast AST-based PHP view engine with #-directives, compile-time caching, layout inheritance, and component support.",
    "type": "library",
    "license": "MIT",
    "keywords": ["template", "view", "engine", "php", "blade-like", "ast", "compiler"],
    "homepage": "https://github.com/bynhan/sharp",
    "readme": "README.md",
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Sharp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Sharp\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
